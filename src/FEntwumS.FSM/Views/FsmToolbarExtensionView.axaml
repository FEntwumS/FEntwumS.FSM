<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FEntwumS.FSM.ViewModels"
             x:Class="FEntwumS.FSM.Views.FsmToolbarExtensionView"
             x:DataType="vm:FsmToolbarExtensionViewModel">
    <Button Margin="8,0,0,0"
            Padding="12,6"
            MinHeight="32"
            Command="{Binding OpenEditorCommand}">
        <StackPanel Orientation="Horizontal" Spacing="6">
            <Path Width="16" Height="16"
                  Stretch="Uniform"
                  Fill="#FF8C00"
                  Data="M 8,1 C 4.13,1 1,4.13 1,8 C 1,11.87 4.13,15 8,15 C 11.22,15 13.88,12.86 14.72,9.94 L 14.72,7.5 L 8,7.5 L 8,9 L 13,9 C 12.42,11.34 10.38,13 8,13 C 5.24,13 3,10.76 3,8 C 3,5.24 5.24,3 8,3 C 9.48,3 10.81,3.59 11.79,4.54 L 13.22,3.12 C 11.88,1.81 10.04,1 8,1 Z"
                  VerticalAlignment="Center" />
            <TextBlock Text="FSM Editor" VerticalAlignment="Center" />
        </StackPanel>
    </Button>
</UserControl>