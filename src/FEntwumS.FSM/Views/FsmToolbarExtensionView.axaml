<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FEntwumS.FSM.ViewModels"
             x:Class="FEntwumS.FSM.Views.FsmToolbarExtensionView"
             x:DataType="vm:FsmToolbarExtensionViewModel">
    <Button Content="FSM Editor"
            Margin="8,0,0,0"
            Padding="12,6"
            MinHeight="32"
            Command="{Binding OpenEditorCommand}" />
</UserControl>