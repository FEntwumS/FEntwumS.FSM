<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FEntwumS.FSM.ViewModels"
             xmlns:paz="using:Avalonia.Controls.PanAndZoom"
             x:Class="FEntwumS.FSM.Views.FiniteStateMachineView"
             x:DataType="vm:FiniteStateMachineViewModel"
             x:Name="Root"
             Focusable="True"
             KeyDown="OnEditorKeyDown">
    
    <Grid ColumnDefinitions="250, *">
        
        <Border Grid.Column="0" Background="#252526" BorderBrush="#3e3e42" BorderThickness="0,0,1,0">
         <ScrollViewer VerticalScrollBarVisibility="Auto">
         <StackPanel Margin="15" Spacing="10">
    <TextBlock Text="FSM EDITOR" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

        <Button Content="Add New State" 
            Command="{Binding AddStateCommand}" 
            HorizontalAlignment="Stretch"/>

                <Grid ColumnDefinitions="*,*,Auto"
          ColumnSpacing="8">
        <Button Content="Zoom In"
            Click="OnZoomInClicked"
            HorizontalAlignment="Stretch"/>
        <Button Grid.Column="1"
            Content="Zoom Out"
            Click="OnZoomOutClicked"
            HorizontalAlignment="Stretch"/>
        <Border Grid.Column="2"
            Padding="10,0"
            Background="#1e1e1e"
            CornerRadius="6"
            MinWidth="64">
            <TextBlock x:Name="ZoomLevelText"
                   Text="100%"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontWeight="SemiBold"/>
        </Border>
        </Grid>

        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
            <ToggleButton Content="Grid"
                          IsChecked="{Binding ShowGrid, Mode=TwoWay}"
                          HorizontalAlignment="Stretch"
                          ToolTip.Tip="Show / hide background grid"/>
            <ToggleButton Grid.Column="1"
                          Content="Snap"
                          IsChecked="{Binding SnapToGrid, Mode=TwoWay}"
                          HorizontalAlignment="Stretch"
                          ToolTip.Tip="Snap states to grid when moving"/>
        </Grid>

    <Separator Margin="0,4" Background="#3e3e42"/>
    <TextBlock Text="BACKEND"
               FontWeight="Bold"
               FontSize="12"
               Margin="0,0,0,4"
               Foreground="#b0b0b0"/>

    <Grid ColumnDefinitions="Auto,*,*" ColumnSpacing="6">
        <TextBlock Text="Generate"
                   VerticalAlignment="Center"
                   FontWeight="SemiBold"/>
        <Button Grid.Column="1"
                Content="VHDL"
                Click="OnGenerateVhdlClicked"
                HorizontalAlignment="Stretch"/>
        <Button Grid.Column="2"
                Content="C"
                Click="OnGenerateCClicked"
                HorizontalAlignment="Stretch"/>
    </Grid>

    <Button Content="Verify"
            Click="OnVerifyClicked"
            HorizontalAlignment="Stretch"/>

    <Border Background="#1f1f21"
            BorderBrush="#3e3e42"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10">
        <StackPanel Spacing="8">

            <!-- Signals header: toggle button + count badge + Add button -->
            <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                  ColumnSpacing="6">
                <Button Grid.Column="0"
                        Command="{Binding ToggleSignalsCommand}"
                        Padding="4,2"
                        Background="Transparent"
                        BorderThickness="0">
                    <Panel>
                        <TextBlock Text="▼" FontSize="10" IsVisible="{Binding IsSignalsExpanded}"/>
                        <TextBlock Text="▶" FontSize="10" IsVisible="{Binding !IsSignalsExpanded}"/>
                    </Panel>
                </Button>
                <TextBlock Grid.Column="1"
                           Text="Signals"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <Border Grid.Column="2"
                        Background="#3c3f3f"
                        CornerRadius="8"
                        Padding="5,1"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="4,0,0,0">
                    <TextBlock Text="{Binding Signals.Count}"
                               FontSize="11"
                               Foreground="#c0c0c0"/>
                </Border>
                <Button Grid.Column="3"
                        Content="Add"
                        Command="{Binding AddSignalCommand}"/>
            </Grid>

            <!-- Collapsible signal list -->
            <ItemsControl ItemsSource="{Binding Signals}"
                          IsVisible="{Binding IsSignalsExpanded}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:SignalDefinitionViewModel">
                        <Border Background="#252526"
                                BorderBrush="#3e3e42"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="8"
                                Margin="0,0,0,6">
                            <StackPanel Spacing="6">
                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="8">
                                    <TextBlock Text="Name"
                                               VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Name, Mode=TwoWay}"
                                             GotFocus="OnSignalEditorGotFocus"
                                             LostFocus="OnSignalEditorLostFocus"
                                             KeyDown="OnSignalEditorKeyDown"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="8">
                                    <TextBlock Text="Dir"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1"
                                              SelectedItem="{Binding Direction, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch"
                                              GotFocus="OnSignalEditorGotFocus"
                                              LostFocus="OnSignalEditorLostFocus">
                                        <x:String>IN</x:String>
                                        <x:String>OUT</x:String>
                                        <x:String>INOUT</x:String>
                                    </ComboBox>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="8">
                                    <TextBlock Text="Type"
                                               VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1"
                                              SelectedItem="{Binding Type, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch"
                                              GotFocus="OnSignalEditorGotFocus"
                                              LostFocus="OnSignalEditorLostFocus">
                                        <x:String>BIT</x:String>
                                        <x:String>BIT_N</x:String>
                                        <x:String>SIGNED</x:String>
                                        <x:String>UNSIGNED</x:String>
                                    </ComboBox>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="8"
                                      IsVisible="{Binding HasSize}">
                                    <TextBlock Text="Size"
                                               VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Size, Mode=TwoWay}"
                                             GotFocus="OnSignalEditorGotFocus"
                                             LostFocus="OnSignalEditorLostFocus"
                                             KeyDown="OnSignalEditorKeyDown"/>
                                </Grid>
                                <Button HorizontalAlignment="Right"
                                        Content="Delete"
                                        Click="OnDeleteSignalClicked"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Border>

    <!-- Variables section -->
    <Border Background="#1f1f21"
            BorderBrush="#3e3e42"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10">
        <StackPanel Spacing="8">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="6">
                <Button Grid.Column="0" Command="{Binding ToggleVariablesCommand}"
                        Padding="4,2" Background="Transparent" BorderThickness="0">
                    <Panel>
                        <TextBlock Text="▼" FontSize="10" IsVisible="{Binding IsVariablesExpanded}"/>
                        <TextBlock Text="▶" FontSize="10" IsVisible="{Binding !IsVariablesExpanded}"/>
                    </Panel>
                </Button>
                <TextBlock Grid.Column="1" Text="Variables" FontWeight="Bold" VerticalAlignment="Center"/>
                <Border Grid.Column="2" Background="#3c3f3f" CornerRadius="8" Padding="5,1"
                        HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,0,0,0">
                    <TextBlock Text="{Binding Variables.Count}" FontSize="11" Foreground="#c0c0c0"/>
                </Border>
                <Button Grid.Column="3" Content="Add" Command="{Binding AddVariableCommand}"/>
            </Grid>
            <ItemsControl ItemsSource="{Binding Variables}" IsVisible="{Binding IsVariablesExpanded}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:VariableDefinitionViewModel">
                        <Border Background="#252526" BorderBrush="#3e3e42" BorderThickness="1"
                                CornerRadius="6" Padding="8" Margin="0,0,0,6">
                            <StackPanel Spacing="6">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <TextBlock Text="Name" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding Name, Mode=TwoWay}"/>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <TextBlock Text="Type" VerticalAlignment="Center"/>
                                    <ComboBox Grid.Column="1" SelectedItem="{Binding Type, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch">
                                        <x:String>BIT</x:String>
                                        <x:String>BIT_N</x:String>
                                        <x:String>SIGNED</x:String>
                                        <x:String>UNSIGNED</x:String>
                                    </ComboBox>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8"
                                      IsVisible="{Binding HasSize}">
                                    <TextBlock Text="Size" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" Text="{Binding Size, Mode=TwoWay}"/>
                                </Grid>
                                <Button HorizontalAlignment="Right" Content="Delete"
                                        Click="OnDeleteVariableClicked"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</StackPanel>
        </ScrollViewer>
        </Border>

                <Grid Grid.Column="1">
                <paz:ZoomBorder x:Name="ZoomBorder"
                                Background="#1e1e1e"
                                ClipToBounds="True"
                                Focusable="True"
                                PanButton="Right"
                                EnablePan="True"
                                EnableZoom="True"
                                EnableConstrains="False"
                                EnableDoubleClickZoom="False"
                                Stretch="None"
                                MinZoomX="0.1"
                                MaxZoomX="5.0"
                                MinZoomY="0.1"
                                MaxZoomY="5.0"
                                ZoomChanged="OnZoomChanged"
                                DoubleTapped="OnCanvasDoubleTapped"
                                PointerPressed="OnCanvasPointerPressed"
                                PointerMoved="OnCanvasPointerMoved"
                                PointerReleased="OnCanvasPointerReleased"
                                PointerExited="OnCanvasPointerExited">
                                <Grid x:Name="EditorContent"
                                      Width="20000"
                                      Height="20000"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top">

                        <!-- Dot grid background -->
                        <Rectangle Width="20000" Height="20000"
                                   IsHitTestVisible="False"
                                   IsVisible="{Binding ShowGrid}">
                            <Rectangle.Fill>
                                <DrawingBrush TileMode="Tile"
                                              DestinationRect="0,0,50,50">
                                    <DrawingBrush.Drawing>
                                        <GeometryDrawing>
                                            <GeometryDrawing.Geometry>
                                                <RectangleGeometry Rect="0,0,50,50"/>
                                            </GeometryDrawing.Geometry>
                                            <GeometryDrawing.Pen>
                                                <Pen Brush="#22ffffff" Thickness="0.5"/>
                                            </GeometryDrawing.Pen>
                                        </GeometryDrawing>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <!-- Initial Transitions -->
                        <ItemsControl ItemsSource="{Binding InitialTransitions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><Canvas /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerTheme>
                                <ControlTheme TargetType="ContentPresenter" x:DataType="vm:TransitionViewModel">
                                    <Setter Property="Canvas.Left" Value="0"/>
                                    <Setter Property="Canvas.Top" Value="0"/>
                                </ControlTheme>
                            </ItemsControl.ItemContainerTheme>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TransitionViewModel">
                                    <Canvas Width="5000" Height="5000">
                                        <!-- Hit test transparent path -->
                                        <Path Data="{Binding PathData}" Stroke="Transparent" StrokeThickness="14"
                                              PointerPressed="OnTransitionPointerPressed" PointerMoved="OnTransitionPointerMoved"
                                              PointerReleased="OnTransitionPointerReleased" Tapped="OnTransitionTapped"
                                              DoubleTapped="OnTransitionDoubleTapped"
                                              PointerEntered="OnTransitionPointerEntered"
                                              PointerExited="OnTransitionPointerExited"/>
                                        <!-- Hover glow -->
                                        <Path Data="{Binding PathData}" Stroke="#664A90D9" StrokeThickness="10"
                                              IsVisible="{Binding IsHovered}" IsHitTestVisible="False"/>
                                        <!-- Selection glow -->
                                        <Path Data="{Binding PathData}" Stroke="#66FBBF24" StrokeThickness="10"
                                              IsVisible="{Binding IsSelected}"/>
                                        <!-- Main white path -->
                                        <Path Data="{Binding PathData}" Stroke="White" StrokeThickness="3"/>
                                        <!-- Selected yellow path -->
                                        <Path Data="{Binding PathData}" Stroke="#FBBF24" StrokeThickness="5"
                                              IsVisible="{Binding IsSelected}"/>
                                        <!-- Arrowhead -->
                                        <Path Data="{Binding ArrowHeadData}" Fill="White" Stroke="White" StrokeThickness="2"/>
                                        <!-- Filled start dot (FSM initial state marker) - draggable -->
                                        <Path Data="{Binding StartDotData}" Fill="White" Stroke="White" StrokeThickness="1"
                                              Tag="start"
                                              PointerPressed="OnTransitionHandlePointerPressed"
                                              PointerMoved="OnTransitionHandlePointerMoved"
                                              PointerReleased="OnTransitionHandlePointerReleased"
                                              Cursor="SizeAll"/>
                                        <!-- Start handle (moves free start point) -->
                                        <Border Canvas.Left="{Binding StartHandleLeft}" Canvas.Top="{Binding StartHandleTop}"
                                                Width="20" Height="20" Background="#01FFFFFF" CornerRadius="10"
                                                Tag="start"
                                                PointerPressed="OnTransitionHandlePointerPressed"
                                                PointerMoved="OnTransitionHandlePointerMoved"
                                                PointerReleased="OnTransitionHandlePointerReleased"
                                                IsVisible="{Binding IsSelected}">
                                            <Ellipse Width="20" Height="20" Fill="#F8FAFC" Stroke="#0EA5E9"
                                                     StrokeThickness="2" IsHitTestVisible="False"/>
                                        </Border>
                                        <!-- Bend handle -->
                                        <Border Canvas.Left="{Binding BendHandleLeft}" Canvas.Top="{Binding BendHandleTop}"
                                                Width="12" Height="12" Background="#01FFFFFF" CornerRadius="6"
                                                Tag="bend"
                                                PointerPressed="OnTransitionHandlePointerPressed"
                                                PointerMoved="OnTransitionHandlePointerMoved"
                                                PointerReleased="OnTransitionHandlePointerReleased"
                                                IsVisible="{Binding IsSelected}">
                                            <Ellipse Width="12" Height="12" Fill="#FBBF24" Stroke="#78350F"
                                                     StrokeThickness="2" IsHitTestVisible="False"/>
                                        </Border>
                                        <!-- Condition label (view mode) -->
                                        <Border Canvas.Left="{Binding LabelLeft}" Canvas.Top="{Binding LabelTop}"
                                                Background="#252526" Width="{Binding LabelWidth}" Height="{Binding LabelHeight}"
                                                Padding="4,2" CornerRadius="4" BorderBrush="#3e3e42" BorderThickness="1"
                                                PointerPressed="OnTransitionPointerPressed" PointerMoved="OnTransitionPointerMoved"
                                                PointerReleased="OnTransitionPointerReleased" Tapped="OnTransitionTapped"
                                                DoubleTapped="OnTransitionDoubleTapped"
                                                IsVisible="{Binding !IsEditingCondition}">
                                            <TextBlock Text="{Binding DisplayCondition}" Foreground="White"
                                                       HorizontalAlignment="Center" TextAlignment="Center" FontSize="11"/>
                                        </Border>
                                        <!-- Selection border on label -->
                                        <Border Canvas.Left="{Binding LabelLeft}" Canvas.Top="{Binding LabelTop}"
                                                Background="Transparent" Width="{Binding LabelWidth}" Height="{Binding LabelHeight}"
                                                Padding="6,4" CornerRadius="6" BorderBrush="#FBBF24" BorderThickness="2"
                                                IsHitTestVisible="False" IsVisible="{Binding IsSelected}"/>
                                        <!-- Condition editor TextBox -->
                                        <TextBox Canvas.Left="{Binding LabelLeft}" Canvas.Top="{Binding LabelTop}"
                                                 Width="{Binding LabelEditorWidth}" Height="{Binding LabelHeight}"
                                                 Text="{Binding Condition, Mode=TwoWay}"
                                                 IsVisible="{Binding IsEditingCondition}"
                                                 KeyDown="OnTransitionConditionKeyDown"
                                                 LostFocus="OnTransitionConditionLostFocus"/>
                                        <!-- Output label (Mealy only) -->
                                        <Border Canvas.Left="{Binding OutputLabelLeft}"
                                                Canvas.Top="{Binding OutputLabelTop}"
                                                Background="#1F2937"
                                                Width="{Binding OutputLabelWidth}"
                                                Height="{Binding OutputLabelHeight}"
                                                Padding="4,2"
                                                CornerRadius="4"
                                                BorderBrush="#3e3e42"
                                                BorderThickness="1"
                                                DoubleTapped="OnTransitionOutputDoubleTapped"
                                                IsVisible="{Binding #Root.DataContext.IsMealyGraph}">
                                            <TextBlock Text="{Binding DisplayOutputAssignments}"
                                                       Foreground="#DDEBFF"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       FontSize="10"
                                                       TextWrapping="Wrap"/>
                                        </Border>
                                        <TextBox Canvas.Left="{Binding OutputLabelLeft}"
                                                 Canvas.Top="{Binding OutputLabelTop}"
                                                 Width="{Binding OutputEditorWidth}"
                                                 Height="{Binding OutputEditorHeight}"
                                                 Text="{Binding OutputAssignments, Mode=TwoWay}"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 IsVisible="{Binding IsEditingOutputAssignments}"
                                                 KeyDown="OnTransitionOutputKeyDown"
                                                 LostFocus="OnTransitionOutputLostFocus"
                                                 TextChanged="OnOutputAssignmentsTextChanged"/>
                                    </Canvas>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding Transitions}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemContainerTheme>
                    <ControlTheme TargetType="ContentPresenter" x:DataType="vm:TransitionViewModel">
                        <Setter Property="Canvas.Left" Value="0"/>
                        <Setter Property="Canvas.Top" Value="0"/>
                    </ControlTheme>
                </ItemsControl.ItemContainerTheme>

                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:TransitionViewModel">
                        <Canvas Width="5000" Height="5000">
                            <Canvas.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Delete"
                                              Click="OnDeleteTransitionClicked"/>
                                </ContextMenu>
                            </Canvas.ContextMenu>
                            <Path Data="{Binding PathData}"
                                  Stroke="Transparent"
                                  StrokeThickness="14"
                                                                    PointerPressed="OnTransitionPointerPressed"
                                                                    PointerMoved="OnTransitionPointerMoved"
                                                                    PointerReleased="OnTransitionPointerReleased"
                                                                    Tapped="OnTransitionTapped"
                                  DoubleTapped="OnTransitionDoubleTapped"
                                  PointerEntered="OnTransitionPointerEntered"
                                  PointerExited="OnTransitionPointerExited"/>
                            <!-- Hover glow -->
                            <Path Data="{Binding PathData}"
                                  Stroke="#664A90D9"
                                  StrokeThickness="10"
                                  IsVisible="{Binding IsHovered}"
                                  IsHitTestVisible="False"/>
                                <Path Data="{Binding PathData}"
                                    Stroke="#66FBBF24"
                                    StrokeThickness="10"
                                    IsVisible="{Binding IsSelected}"/>
                            <Path Data="{Binding PathData}"
                                  Stroke="#3FB5FF"
                                  StrokeThickness="3"/>
                            <Path Data="{Binding PathData}"
                                    Stroke="#FBBF24"
                                    StrokeThickness="5"
                                    IsVisible="{Binding IsSelected}"/>
                            <Path Data="{Binding ArrowHeadData}"
                                  Fill="#3FB5FF"
                                  Stroke="#3FB5FF"
                                  StrokeThickness="2"/>
                               <Border Canvas.Left="{Binding StartHandleLeft}"
                                     Canvas.Top="{Binding StartHandleTop}"
                                     Width="20"
                                     Height="20"
                                     Background="#01FFFFFF"
                                     CornerRadius="10"
                                     Tag="start"
                                     PointerPressed="OnTransitionHandlePointerPressed"
                                     PointerMoved="OnTransitionHandlePointerMoved"
                                     PointerReleased="OnTransitionHandlePointerReleased"
                                     IsVisible="{Binding IsSelected}">
                                  <Ellipse Width="20"
                                         Height="20"
                                         Fill="#F8FAFC"
                                         Stroke="#0EA5E9"
                                         StrokeThickness="2"
                                         IsHitTestVisible="False"/>
                               </Border>
                               <Border Canvas.Left="{Binding EndHandleLeft}"
                                     Canvas.Top="{Binding EndHandleTop}"
                                     Width="20"
                                     Height="20"
                                     Background="#01FFFFFF"
                                     CornerRadius="10"
                                     Tag="end"
                                     PointerPressed="OnTransitionHandlePointerPressed"
                                     PointerMoved="OnTransitionHandlePointerMoved"
                                     PointerReleased="OnTransitionHandlePointerReleased"
                                     IsVisible="{Binding IsSelected}">
                                  <Ellipse Width="20"
                                         Height="20"
                                         Fill="#F8FAFC"
                                         Stroke="#0EA5E9"
                                         StrokeThickness="2"
                                         IsHitTestVisible="False"/>
                               </Border>
                               <Border Canvas.Left="{Binding BendHandleLeft}"
                                     Canvas.Top="{Binding BendHandleTop}"
                                     Width="12"
                                     Height="12"
                                     Background="#01FFFFFF"
                                     CornerRadius="6"
                                     Tag="bend"
                                     PointerPressed="OnTransitionHandlePointerPressed"
                                     PointerMoved="OnTransitionHandlePointerMoved"
                                     PointerReleased="OnTransitionHandlePointerReleased"
                                     IsVisible="{Binding IsSelected}">
                                  <Ellipse Width="12"
                                         Height="12"
                                         Fill="#FBBF24"
                                         Stroke="#78350F"
                                         StrokeThickness="2"
                                         IsHitTestVisible="False"/>
                               </Border>
                            <Border Canvas.Left="{Binding LabelLeft}"
                                    Canvas.Top="{Binding LabelTop}"
                                    Background="#252526"
                                    Width="{Binding LabelWidth}"
                                    Height="{Binding LabelHeight}"
                                    Padding="4,2"
                                    CornerRadius="4"
                                    BorderBrush="#3e3e42"
                                    BorderThickness="1"
                                    PointerPressed="OnTransitionPointerPressed"
                                    PointerMoved="OnTransitionPointerMoved"
                                    PointerReleased="OnTransitionPointerReleased"
                                    Tapped="OnTransitionTapped"
                                    DoubleTapped="OnTransitionDoubleTapped"
                                    IsVisible="{Binding !IsEditingCondition}">
                                <TextBlock Text="{Binding DisplayCondition}"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           FontSize="11"/>
                            </Border>
                            <Border Canvas.Left="{Binding LabelLeft}"
                                    Canvas.Top="{Binding LabelTop}"
                                    Background="Transparent"
                                    Width="{Binding LabelWidth}"
                                    Height="{Binding LabelHeight}"
                                    Padding="6,4"
                                    CornerRadius="6"
                                    BorderBrush="#FBBF24"
                                    BorderThickness="2"
                                    IsHitTestVisible="False"
                                    IsVisible="{Binding IsSelected}" />
                            <TextBox Canvas.Left="{Binding LabelLeft}"
                                     Canvas.Top="{Binding LabelTop}"
                                     Width="{Binding LabelEditorWidth}"
                                     Height="{Binding LabelHeight}"
                                     Text="{Binding Condition, Mode=TwoWay}"
                                     IsVisible="{Binding IsEditingCondition}"
                                     KeyDown="OnTransitionConditionKeyDown"
                                     LostFocus="OnTransitionConditionLostFocus"/>
                            <Border Canvas.Left="{Binding OutputLabelLeft}"
                                    Canvas.Top="{Binding OutputLabelTop}"
                                    Background="#1F2937"
                                    Width="{Binding OutputLabelWidth}"
                                    Height="{Binding OutputLabelHeight}"
                                    Padding="4,2"
                                    CornerRadius="4"
                                    BorderBrush="#3e3e42"
                                    BorderThickness="1"
                                    PointerPressed="OnTransitionPointerPressed"
                                    PointerMoved="OnTransitionPointerMoved"
                                    PointerReleased="OnTransitionPointerReleased"
                                    Tapped="OnTransitionTapped"
                                    DoubleTapped="OnTransitionOutputDoubleTapped"
                                    IsVisible="{Binding #Root.DataContext.IsMealyGraph}">
                                <TextBlock Text="{Binding DisplayOutputAssignments}"
                                           Foreground="#DDEBFF"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           FontSize="10"
                                           TextWrapping="Wrap"/>
                            </Border>
                            <TextBox Canvas.Left="{Binding OutputLabelLeft}"
                                     Canvas.Top="{Binding OutputLabelTop}"
                                     Width="{Binding OutputEditorWidth}"
                                     Height="{Binding OutputEditorHeight}"
                                     Text="{Binding OutputAssignments, Mode=TwoWay}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     IsVisible="{Binding IsEditingOutputAssignments}"
                                     KeyDown="OnTransitionOutputKeyDown"
                                     LostFocus="OnTransitionOutputLostFocus"
                                     TextChanged="OnOutputAssignmentsTextChanged"/>
                        </Canvas>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl ItemsSource="{Binding DraftTransitions}" IsHitTestVisible="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemContainerTheme>
                    <ControlTheme TargetType="ContentPresenter" x:DataType="vm:TransitionViewModel">
                        <Setter Property="Canvas.Left" Value="0"/>
                        <Setter Property="Canvas.Top" Value="0"/>
                    </ControlTheme>
                </ItemsControl.ItemContainerTheme>

                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:TransitionViewModel">
                        <Canvas Width="5000" Height="5000">
                            <Path Data="{Binding PathData}"
                                  Stroke="#7DD3FF"
                                  StrokeThickness="3"
                                  StrokeDashArray="4,4"/>
                            <Path Data="{Binding ArrowHeadData}"
                                  Fill="#7DD3FF"
                                  Stroke="#7DD3FF"
                                  StrokeThickness="2"/>
                        </Canvas>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl ItemsSource="{Binding States}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemContainerTheme>
                    <ControlTheme TargetType="ContentPresenter" x:DataType="vm:StateItemViewModel">
                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                    </ControlTheme>
                </ItemsControl.ItemContainerTheme>

                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:StateItemViewModel">
                        <Grid PointerPressed="OnPointerPressed"
                              PointerMoved="OnPointerMoved"
                              PointerReleased="OnPointerReleased"
                            PointerEntered="OnStatePointerEntered"
                            PointerExited="OnStatePointerExited"
                              DoubleTapped="OnDoubleTapped"
                              Tapped="OnStateTapped"
                              Background="Transparent"
                              Width="{Binding RenderWidth}"
                              Height="{Binding RenderHeight}">
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Set as Initial State"
                                              Click="OnSetInitialStateClicked"/>
                                    <MenuItem Header="Set as Final State"
                                              Click="OnSetFinalStateClicked"/>
                                    <MenuItem Header="Remove Final State Marker"
                                              Click="OnRemoveFinalStateClicked"/>
                                    <MenuItem Header="Add Self Transition"
                                              Click="OnAddSelfTransitionClicked"/>
                                    <MenuItem Header="Delete"
                                              Click="OnDeleteStateClicked"/>
                                </ContextMenu>
                            </Grid.ContextMenu>

                            <Ellipse Fill="#3c3c3c" Stroke="DodgerBlue" StrokeThickness="2"/>
                            <!-- Final state double-circle inner ring -->
                            <Ellipse Fill="Transparent"
                                     Stroke="DodgerBlue"
                                     StrokeThickness="2"
                                     Margin="10"
                                     IsHitTestVisible="False"
                                     IsVisible="{Binding IsFinalState}"/>
                            <!-- Hover glow ring -->
                            <Ellipse Fill="Transparent"
                                     Stroke="#4A90D9"
                                     StrokeThickness="4"
                                     Margin="-6"
                                     IsHitTestVisible="False"
                                     Opacity="0.75"
                                     IsVisible="{Binding IsHovered}"/>
                            <Ellipse Fill="Transparent"
                                     Stroke="#FBBF24"
                                     StrokeThickness="5"
                                     Margin="-8"
                                     IsHitTestVisible="False"
                                     IsVisible="{Binding IsSelected}"/>

                            <Ellipse Width="10" Height="10" Fill="#FBBF24" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,4,0,0" IsHitTestVisible="False" IsVisible="{Binding IsSelected}"/>
                            <Ellipse Width="10" Height="10" Fill="#FBBF24" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" IsHitTestVisible="False" IsVisible="{Binding IsSelected}"/>
                            <Ellipse Width="10" Height="10" Fill="#FBBF24" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,4" IsHitTestVisible="False" IsVisible="{Binding IsSelected}"/>
                            <Ellipse Width="10" Height="10" Fill="#FBBF24" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,0,0,0" IsHitTestVisible="False" IsVisible="{Binding IsSelected}"/>

                            <Canvas IsHitTestVisible="False">
                                <Ellipse Width="12"
                                         Height="12"
                                         Fill="#F8FAFC"
                                         Stroke="#0EA5E9"
                                         StrokeThickness="2"
                                         Canvas.Left="{Binding HoverAnchorLeft}"
                                         Canvas.Top="{Binding HoverAnchorTop}"
                                         IsVisible="{Binding IsHoverAnchorVisible}"/>
                            </Canvas>

                            <Path Data="M -40,50 L 0,50 M -12,42 L 0,50 L -12,58 L -12,42"
                                  Stroke="Transparent"
                                  StrokeThickness="3"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Top"
                                  IsHitTestVisible="False"
                                  IsVisible="False" />

                            <StackPanel IsVisible="{Binding !IsEditing}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Width="82"
                                        Spacing="4">
                                <TextBlock Text="{Binding Id}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap"/>
                                <Panel IsVisible="{Binding #Root.DataContext.IsMooreGraph}">
                                    <Border Background="#223FB5FF"
                                            CornerRadius="6"
                                            Padding="6,3"
                                            IsVisible="{Binding HasOutputAssignments}">
                                        <TextBlock Text="{Binding DisplayOutputAssignments}"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   FontSize="10"
                                                   Foreground="#DDEBFF"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                </Panel>
                            </StackPanel>

                            <StackPanel IsVisible="{Binding IsEditing}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Width="82"
                                        Spacing="4">
                                <TextBox Text="{Binding Id, Mode=TwoWay}"
                                         MinWidth="60"
                                         HorizontalAlignment="Stretch"
                                         KeyDown="OnStateEditorKeyDown"
                                         LostFocus="OnStateEditorLostFocus"/>
                                <TextBox Text="{Binding OutputAssignments, Mode=TwoWay}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="44"
                                         IsVisible="{Binding #Root.DataContext.IsMooreGraph}"
                                         HorizontalAlignment="Stretch"
                                         KeyDown="OnStateEditorKeyDown"
                                         LostFocus="OnStateEditorLostFocus"
                                         TextChanged="OnOutputAssignmentsTextChanged"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border x:Name="SelectionRectangle"
                    IsVisible="False"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    BorderBrush="#7DD3FF"
                    BorderThickness="1"
                    Background="#223FB5FF"
                    Width="0"
                    Height="0"
                    IsHitTestVisible="False"
                    ZIndex="1000"/>

            <!-- Ghost state preview shown while in placement mode -->
            <Grid x:Name="GhostState"
                  Width="144"
                  Height="64"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Top"
                  IsVisible="False"
                  IsHitTestVisible="False"
                  Opacity="0.55"
                  ZIndex="1001">
                <Ellipse Fill="#3c3c3c"
                         Stroke="DodgerBlue"
                         StrokeThickness="2"
                         StrokeDashArray="6,3"/>
                <TextBlock Text="New State"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#bbffffff"
                           FontSize="11"
                           IsHitTestVisible="False"/>
            </Grid>
                </Grid>
                </paz:ZoomBorder>

                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top"
                            Margin="12,12,0,0" IsHitTestVisible="False" Spacing="1"
                            Opacity="0.7">
                    <TextBlock Text="{Binding Title}"
                               Foreground="White"
                               FontWeight="SemiBold"
                               FontSize="13"/>
                    <TextBlock Text="{Binding GraphType}"
                               Foreground="#a0a0a0"
                               FontSize="11"/>
                </StackPanel>
                </Grid>
        
    </Grid>
</UserControl>