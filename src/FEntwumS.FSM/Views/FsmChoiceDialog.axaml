<controls:FlexibleWindow xmlns="https://github.com/avaloniaui"
                         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                         xmlns:controls="using:OneWare.Essentials.Controls"
                         x:Class="FEntwumS.FSM.Views.FsmChoiceDialog"
                         Title="FSM Editor"
                         PrefWidth="380"
                         PrefHeight="220"
                         SizeToContent="Height"
                         WindowStartupLocation="CenterOwner">

    <StackPanel Margin="20,16,20,20" Spacing="12">

        <TextBlock Text="What would you like to do?"
                   FontSize="14"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,4"/>

        <!-- Create New Graph -->
        <Button x:Name="CreateButton"
                HorizontalAlignment="Stretch"
                Padding="16,12"
                Click="OnCreateClicked">
            <StackPanel Spacing="4">
                <TextBlock Text="Create New Graph"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Start a blank state diagram in your project"
                           FontSize="11"
                           Opacity="0.7"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Button>

        <!-- Load Existing Graph -->
        <Button x:Name="LoadButton"
                HorizontalAlignment="Stretch"
                Padding="16,12"
                Click="OnLoadClicked">
            <StackPanel Spacing="4">
                <TextBlock Text="Load Existing Graph"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Open a .fsmxml file from the current project"
                           FontSize="11"
                           Opacity="0.7"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Button>

    </StackPanel>

</controls:FlexibleWindow>
