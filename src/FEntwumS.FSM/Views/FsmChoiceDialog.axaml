<controls:FlexibleWindow xmlns="https://github.com/avaloniaui"
                         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                         xmlns:controls="using:OneWare.Essentials.Controls"
                         x:Class="FEntwumS.FSM.Views.FsmChoiceDialog"
                         Title="FSM Editor"
                         PrefWidth="380"
                         PrefHeight="220"
                         SizeToContent="Height"
                         WindowStartupLocation="CenterOwner">

    <StackPanel Margin="20,16,20,20" Spacing="12">

        <TextBlock Text="What would you like to do?"
                   FontSize="14"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,4"/>

        <!-- Create New Graph -->
        <Border Background="#1a1a1c"
                BorderBrush="#3e3e42"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,10">
            <StackPanel Spacing="8">
                <TextBlock Text="Create New Graph"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Choose a graph type:"
                           FontSize="11"
                           Opacity="0.7"
                           HorizontalAlignment="Center"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="16">
                    <RadioButton x:Name="MooreRadio"
                                 Content="Moore"
                                 GroupName="GraphType"
                                 Checked="OnGraphTypeChecked"/>
                    <RadioButton x:Name="MealyRadio"
                                 Content="Mealy"
                                 GroupName="GraphType"
                                 Checked="OnGraphTypeChecked"/>
                </StackPanel>
                <Button x:Name="CreateButton"
                        HorizontalAlignment="Stretch"
                        Padding="12,8"
                        IsEnabled="False"
                        Click="OnCreateClicked">
                    <TextBlock Text="Create" HorizontalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- Load Existing Graph -->
        <Button x:Name="LoadButton"
                HorizontalAlignment="Stretch"
                Padding="16,12"
                Click="OnLoadClicked">
            <StackPanel Spacing="4">
                <TextBlock Text="Load Existing Graph"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Open a .fsmxml file from the current project"
                           FontSize="11"
                           Opacity="0.7"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Button>

    </StackPanel>

</controls:FlexibleWindow>
